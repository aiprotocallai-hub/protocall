<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">Διαθέσιμο τώρα στην Ελλάδα</div>
    <h1>Το τηλέφωνό σας απαντάει <em>πάντα.</em></h1>
