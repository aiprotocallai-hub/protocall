</section>

<!-- HOW IT WORKS -->
<section class="section" id="how">
  <div class="section-label">Πώς λειτουργεί</div>
  <h2 class="section-title">Τρία βήματα. Κανένα χαμένο ραντεβού.</h2>

  <div class="steps">
    <div class="step">
      <div class="step-num">01</div>
      <div class="step-icon">📵</div>
      <h3>Δεν απαντάτε</h3>
